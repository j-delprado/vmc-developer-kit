# VerifyMyClient Partner MCP server configuration

# Required. Your Partner API token (vmc_test_... or vmc_live_...).
VMC_API_TOKEN=vmc_test_xxxxxxxxxxxxxxxx

# Optional. API base URL. Defaults to production.
# Use the test environment while integrating:
# VMC_API_BASE=https://test.verifymyclient.com/api/v1
VMC_API_BASE=https://verifymyclient.com/api/v1
