{
  "name": "@verifymyclient/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the VerifyMyClient Partner API v1 — create and track identity verifications for Companies House (zero dependencies).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/j-delprado/vmc-developer-kit.git",
    "directory": "sdk"
  },
  "keywords": ["verifymyclient", "identity-verification", "companies-house", "acsp", "kyc", "idv"],
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
